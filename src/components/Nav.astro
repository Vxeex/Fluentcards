---
const { currentPath = '/' } = Astro.props;
const isActive = (path: string) => currentPath.startsWith(path);
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-xl border-b-2 border-primary/15 dark:bg-surface-dark/90 dark:border-emerald-900/30 shadow-[0_4px_30px_rgba(15,189,79,0.06)]">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-sans text-2xl font-extrabold tracking-tight bg-gradient-to-r from-primary to-teal-400 bg-clip-text text-transparent hover:from-primary hover:to-primary transition-all duration-300">
      FluentCards
    </a>

    <!-- Desktop nav links -->
    <div class="hidden sm:flex items-center gap-5">
      <a href="/features/" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors duration-200 relative after:absolute after:bottom-[-2px] after:left-0 after:h-[2px] after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Features</a>
      <a href="/guides/" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors duration-200 relative after:absolute after:bottom-[-2px] after:left-0 after:h-[2px] after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Guides</a>
      <a href="/stories/" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors duration-200 relative after:absolute after:bottom-[-2px] after:left-0 after:h-[2px] after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Stories</a>
      <a href="/blog/" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors duration-200 relative after:absolute after:bottom-[-2px] after:left-0 after:h-[2px] after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Blog</a>
      <a href="/about/" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors duration-200 relative after:absolute after:bottom-[-2px] after:left-0 after:h-[2px] after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full">About</a>
      <a href="/contact/" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors duration-200 relative after:absolute after:bottom-[-2px] after:left-0 after:h-[2px] after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Contact</a>
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <!-- Theme toggle -->
      <button id="theme-toggle" class="w-9 h-9 rounded-xl flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-green-50 dark:hover:bg-emerald-900/30 hover:text-primary transition-colors duration-200 ring-1 ring-slate-200 dark:ring-emerald-900/30 hover:ring-primary/30" aria-label="Toggle dark mode">
        <!-- Sun icon (shown in dark mode) -->
        <svg id="theme-sun" class="hidden dark:inline" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="theme-moon" class="dark:hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a href="/app/" class="hidden sm:inline-flex items-center gap-1.5 bg-primary text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-primary-hover transition-all duration-200 shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/30 active:scale-[0.97]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Open App
      </a>

      <!-- Hamburger button (mobile only) -->
      <button id="mobile-menu-btn" class="sm:hidden w-9 h-9 rounded-xl flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-green-50 dark:hover:bg-emerald-900/30 hover:text-primary transition-colors duration-200 ring-1 ring-slate-200 dark:ring-emerald-900/30" aria-label="Open menu">
        <svg id="hamburger-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="close-icon" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-slate-100 dark:border-emerald-900/20 bg-white/95 dark:bg-surface-dark/95 backdrop-blur-xl">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1">
      <a href="/features/" class="py-2.5 px-3 rounded-lg text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-green-50 dark:hover:bg-emerald-900/20 hover:text-primary transition-colors">Features</a>
      <a href="/guides/" class="py-2.5 px-3 rounded-lg text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-green-50 dark:hover:bg-emerald-900/20 hover:text-primary transition-colors">Guides</a>
      <a href="/stories/" class="py-2.5 px-3 rounded-lg text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-green-50 dark:hover:bg-emerald-900/20 hover:text-primary transition-colors">Stories</a>
      <a href="/blog/" class="py-2.5 px-3 rounded-lg text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-green-50 dark:hover:bg-emerald-900/20 hover:text-primary transition-colors">Blog</a>
      <a href="/about/" class="py-2.5 px-3 rounded-lg text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-green-50 dark:hover:bg-emerald-900/20 hover:text-primary transition-colors">About</a>
      <a href="/contact/" class="py-2.5 px-3 rounded-lg text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-green-50 dark:hover:bg-emerald-900/20 hover:text-primary transition-colors">Contact</a>
      <div class="border-t border-slate-100 dark:border-emerald-900/20 my-2"></div>
      <a href="/app/" class="flex items-center justify-center gap-2 bg-primary text-white px-5 py-3 rounded-xl text-sm font-bold hover:bg-primary-hover transition-all duration-200 shadow-lg shadow-primary/20">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Open App
      </a>
    </div>
  </div>
</nav>

<script>
(function() {
  // Theme toggle
  var themeBtn = document.getElementById('theme-toggle');
  if (themeBtn) {
    themeBtn.addEventListener('click', function() {
      var isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('fluentcards-ui-theme', isDark ? 'dark' : 'light');
    });
  }

  // Mobile menu toggle
  var menuBtn = document.getElementById('mobile-menu-btn');
  var menu = document.getElementById('mobile-menu');
  var hamburgerIcon = document.getElementById('hamburger-icon');
  var closeIcon = document.getElementById('close-icon');
  if (menuBtn && menu) {
    menuBtn.addEventListener('click', function() {
      var isOpen = !menu.classList.contains('hidden');
      if (isOpen) {
        menu.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
      } else {
        menu.classList.remove('hidden');
        hamburgerIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
      }
    });
  }
})();
</script>
