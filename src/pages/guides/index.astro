---
import "../../styles/main.css"
import Nav from "../../components/Nav.astro"
import Footer from "../../components/Footer.astro"
import ThemeInit from "../../components/ThemeInit.astro"
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <ThemeInit />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Language Learning Guides - In-Depth Resources | FluentCards</title>
  <meta name="description" content="Comprehensive guides on language learning with spaced repetition. Evidence-based methods, study systems, and practical frameworks for achieving fluency." />
  <link rel="canonical" href="https://fluentcards.org/guides/" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Language Learning Guides - FluentCards" />
  <meta property="og:description" content="In-depth guides on language learning with spaced repetition, memory science, and study systems." />
  <meta property="og:url" content="https://fluentcards.org/guides/" />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json">
  { "@context": "https://schema.org", "@type": "CollectionPage", "name": "Language Learning Guides", "url": "https://fluentcards.org/guides/" }
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-sans text-slate-700 bg-white dark:bg-surface-dark dark:text-slate-400 antialiased overflow-x-hidden transition-colors duration-300">

<Nav currentPath="/guides/" />

<section class="pt-32 pb-16 px-6 text-center">
  <div class="max-w-2xl mx-auto reveal-up">
    <span class="inline-block bg-gradient-to-r from-primary/20 to-teal-400/20 text-primary px-4 py-1 rounded-full text-sm font-bold mb-4 border border-primary/20">Comprehensive Resources</span>
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">Language Learning Guides</h1>
    <p class="mt-4 text-lg text-slate-500 leading-relaxed">Evidence-based, in-depth guides on how to learn languages effectively with spaced repetition, cognitive science, and proven study systems.</p>
  </div>
</section>

<section class="pb-24 px-6">
  <div class="max-w-5xl mx-auto">

    <!-- Featured guide (larger card) -->
    <a href="/guides/spaced-repetition-science/" class="group block mb-6 bg-gradient-to-br from-primary/5 to-teal-400/5 dark:from-primary/10 dark:to-teal-400/5 rounded-2xl border-2 border-primary/20 dark:border-emerald-900/40 p-8 hover:border-primary hover:shadow-lg hover:-translate-y-1 transition-all duration-300 reveal-pop relative overflow-hidden">
      <span class="absolute top-4 right-4 bg-primary text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">New</span>
      <span class="inline-block bg-primary text-white px-3 py-0.5 rounded-full text-xs font-bold mb-4">Featured Guide</span>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-800 dark:text-slate-200 mb-3 group-hover:text-primary transition-colors">The Complete Guide to Spaced Repetition: From Ebbinghaus to FSRS</h2>
      <p class="text-slate-500 dark:text-slate-400 leading-relaxed mb-4">The definitive, science-backed guide to spaced repetition. Learn how memory works, why forgetting is predictable, and how modern algorithms like FSRS can optimize every minute of your study time. Includes practical implementation strategies, study schedules, and troubleshooting for common problems.</p>
      <div class="flex items-center gap-4 text-xs text-slate-400">
        <span>25 min read</span>
        <span>&middot;</span>
        <span>8 sections</span>
        <span>&middot;</span>
        <span>Intermediate</span>
      </div>
    </a>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <a href="/guides/memory-science-flashcards/" class="group bg-white dark:bg-surface-card rounded-xl border-2 border-primary/20 dark:border-emerald-900/40 p-6 hover:border-primary hover:-translate-y-1 hover:shadow-md transition-all duration-300 reveal-pop delay-1 relative">
        <span class="absolute -top-2.5 -right-2.5 bg-primary text-white text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-wider">New</span>
        <span class="inline-block bg-primary text-white px-3 py-0.5 rounded-full text-xs font-bold mb-4">Guide</span>
        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200 mb-2 leading-snug group-hover:text-primary transition-colors">The Science of Memory: How Flashcards Rewire Your Brain</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-4 line-clamp-3">Understand the neuroscience behind effective learning. How neurons encode memories, why active recall strengthens neural pathways, and how sleep consolidates what you study.</p>
        <div class="flex items-center gap-3 text-xs text-slate-400">
          <span>20 min read</span>
          <span>&middot;</span>
          <span>6 sections</span>
          <span>&middot;</span>
          <span>Intermediate</span>
        </div>
      </a>

      <a href="/guides/language-learning-habit/" class="group bg-white dark:bg-surface-card rounded-xl border-2 border-primary/20 dark:border-emerald-900/40 p-6 hover:border-primary hover:-translate-y-1 hover:shadow-md transition-all duration-300 reveal-pop delay-2 relative">
        <span class="absolute -top-2.5 -right-2.5 bg-primary text-white text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-wider">New</span>
        <span class="inline-block bg-primary text-white px-3 py-0.5 rounded-full text-xs font-bold mb-4">Guide</span>
        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200 mb-2 leading-snug group-hover:text-primary transition-colors">The 90-Day Language Learning Framework</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-4 line-clamp-3">A structured 90-day system for building a sustainable language learning habit. Combines spaced repetition with immersive practice, goal setting, and progress tracking.</p>
        <div class="flex items-center gap-3 text-xs text-slate-400">
          <span>22 min read</span>
          <span>&middot;</span>
          <span>7 sections</span>
          <span>&middot;</span>
          <span>Beginner</span>
        </div>
      </a>
    </div>

    <div class="text-center mt-10 reveal-up">
      <p class="text-sm text-slate-400">More guides coming soon. <a href="/blog/" class="text-primary font-semibold hover:text-primary-hover">Visit the blog</a> for shorter articles and language-specific tips.</p>
    </div>
  </div>
</section>

<Footer />

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal-up, .reveal-pop').forEach(el => observer.observe(el));
</script>
</body>
</html>
