---
import "../styles/main.css"
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pricing - FluentCards is Free for Everyone</title>
  <meta name="description" content="FluentCards is completely free to use. No subscriptions, no hidden fees. Get full access to spaced repetition, TTS, furigana, AI mnemonics, and the community marketplace." />
  <link rel="canonical" href="https://fluentcards.org/pricing/" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-sans text-slate-700 bg-white antialiased overflow-x-hidden">

<Nav currentPath="/pricing/" />

<main class="pt-32 pb-20 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="text-center max-w-xl mx-auto reveal-up">
      <span class="text-xs font-bold tracking-widest text-primary uppercase">Pricing</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 mt-2 mb-3">Completely Free, Forever</h1>
      <p class="text-lg text-slate-500 font-[500] mb-16">No subscriptions. No premium tiers. No hidden charges. Every feature is available to everyone.</p>
    </div>

    <!-- Feature Table -->
    <div class="bg-white border-2 border-slate-200 rounded-2xl overflow-hidden shadow-sm reveal-up delay-1">
      <div class="bg-primary text-white text-center py-6 px-6">
        <p class="text-4xl font-extrabold tracking-tight">Free</p>
        <p class="text-primary-light font-medium mt-1">For everyone, forever</p>
      </div>
      <div class="divide-y divide-slate-100">
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 font-semibold">FSRS Spaced Repetition</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50">
          <span class="text-slate-700 font-semibold">Unlimited Flashcards</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 font-semibold">Unlimited Decks</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50">
          <span class="text-slate-700 font-semibold">Native TTS Pronunciation</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 font-semibold">Furigana Support</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50">
          <span class="text-slate-700 font-semibold">AI-Powered Mnemonics</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 font-semibold">Community Marketplace</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50">
          <span class="text-slate-700 font-semibold">Review History & Stats</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 font-semibold">Cross-Device Sync</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50">
          <span class="text-slate-700 font-semibold">Import & Export Decks</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
      </div>

      <div class="px-6 py-6 text-center border-t border-slate-200">
        <a href="/app/" class="group inline-flex items-center gap-2.5 bg-primary text-white px-10 py-4 rounded-xl font-bold text-lg shadow-lg shadow-blue-200 hover:shadow-xl hover:shadow-blue-300 hover:bg-primary-hover active:scale-[0.97] transition-all duration-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Get Started Free
        </a>
        <p class="text-xs text-slate-400 mt-3">No credit card required. No account needed to browse.</p>
      </div>
    </div>

    <!-- Why Free -->
    <section class="mt-16 reveal-up delay-2">
      <h2 class="text-2xl font-bold text-slate-900 mb-4 text-center">Why is FluentCards Free?</h2>
      <div class="grid sm:grid-cols-2 gap-5">
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
          <h3 class="text-base font-bold text-slate-800 mb-2">Our Mission</h3>
          <p class="text-sm text-slate-500 leading-relaxed">We believe language learning should be accessible to everyone. Education isn't a luxury — it's a necessity.</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
          <h3 class="text-base font-bold text-slate-800 mb-2">Supported by Ads</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Non-intrusive advertisements help us cover hosting and API costs. We never sell your personal data.</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200 sm:col-span-2">
          <h3 class="text-base font-bold text-slate-800 mb-2">Built by Learners</h3>
          <p class="text-sm text-slate-500 leading-relaxed">FluentCards started as a personal project and grew into a community tool. We're learners ourselves, and we build features we actually use.</p>
        </div>
      </div>
    </section>

    <!-- Comparison -->
    <section class="mt-16 reveal-up delay-3">
      <h2 class="text-2xl font-bold text-slate-900 mb-4 text-center">How We Compare</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b-2 border-slate-200">
              <th class="text-left py-3 px-4 font-bold text-slate-700">Feature</th>
              <th class="text-center py-3 px-4 font-bold text-primary">FluentCards</th>
              <th class="text-center py-3 px-4 font-bold text-slate-500">Anki</th>
              <th class="text-center py-3 px-4 font-bold text-slate-500">Other Apps</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700">Price</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Free</td>
              <td class="text-center py-3 px-4 text-slate-500">Free (desktop) / $25 (iOS)</td>
              <td class="text-center py-3 px-4 text-slate-500">$5-15/mo subscription</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700">Algorithm</td>
              <td class="text-center py-3 px-4 text-slate-500">FSRS-5</td>
              <td class="text-center py-3 px-4 text-slate-500">SM-2 / FSRS-5 (optional)</td>
              <td class="text-center py-3 px-4 text-slate-500">Varies</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700">Furigana</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Built-in</td>
              <td class="text-center py-3 px-4 text-slate-500">Requires add-on</td>
              <td class="text-center py-3 px-4 text-slate-500">Rarely available</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700">TTS Pronunciation</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Built-in</td>
              <td class="text-center py-3 px-4 text-slate-500">Requires add-on</td>
              <td class="text-center py-3 px-4 text-slate-500">Often premium</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700">AI Mnemonics</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Built-in</td>
              <td class="text-center py-3 px-4 text-slate-500">Not available</td>
              <td class="text-center py-3 px-4 text-slate-500">Rarely available</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- CTA -->
    <div class="mt-16 text-center reveal-up">
      <p class="text-slate-500 mb-6">No catches. No trials. Just the best free flashcard app for language learners.</p>
      <a href="/app/" class="group inline-flex items-center gap-2.5 bg-primary text-white px-10 py-4 rounded-xl font-bold text-lg shadow-lg shadow-blue-200 hover:shadow-xl hover:shadow-blue-300 hover:bg-primary-hover active:scale-[0.97] transition-all duration-200">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Start Learning Free
      </a>
    </div>
  </div>
</main>

<Footer />

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal-up').forEach(el => observer.observe(el));
</script>
</body>
</html>
