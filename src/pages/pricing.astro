---
import "../styles/main.css"
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
import ThemeInit from "../components/ThemeInit.astro"
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <ThemeInit />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pricing - FluentCards is Completely Free, No Subscriptions</title>
  <meta name="description" content="FluentCards is 100% free with no subscriptions, premium tiers, or hidden fees. Get full access to FSRS spaced repetition, TTS pronunciation, furigana, AI mnemonics, and the community marketplace. No credit card required." />
  <link rel="canonical" href="https://fluentcards.org/pricing/" />
  <!-- Open Graph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Pricing - FluentCards is Completely Free, No Subscriptions" />
  <meta property="og:description" content="FluentCards is 100% free with no subscriptions, premium tiers, or hidden fees. Get full access to FSRS spaced repetition, TTS pronunciation, furigana, AI mnemonics, and the community marketplace." />
  <meta property="og:url" content="https://fluentcards.org/pricing/" />
  <meta property="og:site_name" content="FluentCards" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Pricing - FluentCards is Completely Free, No Subscriptions" />
  <meta name="twitter:description" content="100% free flashcard app with no subscriptions or hidden fees." />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "FluentCards",
    "description": "Free flashcard app for language learning with spaced repetition, TTS, furigana, and AI mnemonics.",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "description": "Free forever. No subscription required."
    }
  }
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-sans text-slate-700 bg-white dark:bg-surface-dark dark:text-slate-400 antialiased overflow-x-hidden transition-colors duration-300">

<Nav currentPath="/pricing/" />

<main class="pt-32 pb-20 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="text-center max-w-xl mx-auto reveal-up">
      <span class="text-xs font-bold tracking-widest text-primary uppercase">Pricing</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-slate-200 mt-2 mb-3">Free for Everyone, Forever</h1>
      <p class="text-lg text-slate-500 dark:text-slate-400 font-[500] mb-4">No subscriptions. No premium tiers. No hidden charges.</p>
      <p class="text-sm text-slate-400 mb-16">Every feature is available to every user. Period.</p>
    </div>

    <!-- Feature Table -->
    <div class="bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 rounded-2xl overflow-hidden shadow-sm reveal-up delay-1">
      <div class="bg-primary text-white text-center py-8 px-6">
        <p class="text-5xl font-extrabold tracking-tight">$0</p>
        <p class="text-primary-light font-medium mt-1">Free forever &middot; No credit card needed</p>
      </div>
      <div class="divide-y divide-slate-100 dark:divide-slate-700">
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">FSRS-5 Spaced Repetition</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50 dark:bg-slate-900">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">Unlimited Flashcards & Decks</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">Native TTS Pronunciation (20+ languages)</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50 dark:bg-slate-900">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">Furigana Support for Japanese</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">AI-Powered Mnemonics</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50 dark:bg-slate-900">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">Community Marketplace</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">Review History & FSRS Analytics</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50 dark:bg-slate-900">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">Cross-Device Sync (Firebase)</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">Import & Export (CSV/JSON)</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6 bg-slate-50 dark:bg-slate-900">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">Auto-translate</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex items-center justify-between py-4 px-6">
          <span class="text-slate-700 dark:text-slate-300 font-semibold">Bulk Card Creation</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
      </div>

      <div class="px-6 py-8 text-center border-t border-slate-200 dark:border-slate-600">
        <a href="/app/" class="group inline-flex items-center gap-2.5 bg-primary text-white px-10 py-4 rounded-xl font-bold text-lg shadow-lg shadow-green-200 hover:shadow-xl hover:shadow-green-300 hover:bg-primary-hover active:scale-[0.97] transition-all duration-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Get Started Free
        </a>
        <p class="text-xs text-slate-400 dark:text-slate-400 mt-3">No account required to browse. Sign in with Google when you're ready to study.</p>
      </div>
    </div>

    <!-- Why Free -->
    <section class="mt-16 reveal-up delay-2">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-200 mb-6 text-center">How FluentCards Stays Free</h2>
      <p class="text-slate-500 dark:text-slate-400 text-center max-w-xl mx-auto mb-8 leading-relaxed">We keep the app free through a combination of sustainable choices. No venture capital, no investors — just a straightforward approach to covering costs.</p>
      <div class="grid sm:grid-cols-3 gap-5">
        <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-600">
          <div class="w-10 h-10 rounded-lg bg-primary-light flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Non-Intrusive Ads</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Modest AdSense advertisements help cover hosting and API costs. Ads are placed thoughtfully and never interfere with the learning experience. We don't use pop-ups, interstitials, or autoplay video ads.</p>
        </div>
        <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-600">
          <div class="w-10 h-10 rounded-lg bg-primary-light flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          </div>
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Efficient Infrastructure</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Hosted on Cloudflare Workers with edge caching — server costs stay low even as the user base grows. Firebase Firestore's free tier covers the data needs of most users. We optimize aggressively to keep operating costs minimal.</p>
        </div>
        <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-600">
          <div class="w-10 h-10 rounded-lg bg-primary-light flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><path d="M9 9h.01"/><path d="M15 9h.01"/></svg>
          </div>
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Built by Learners</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">FluentCards started as a personal project and remains a lean operation. We build features we actually use ourselves. There are no salaried executives, no office rent, and no marketing budget — just development time contributed by people who believe in the mission.</p>
        </div>
      </div>
    </section>

    <!-- Comparison -->
    <section class="mt-16 reveal-up delay-3">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-200 mb-4 text-center">How We Compare to Other Apps</h2>
      <p class="text-slate-500 dark:text-slate-400 text-center max-w-xl mx-auto mb-8 leading-relaxed">We built FluentCards because existing options were either expensive, complicated, or missing essential features. Here's how we stack up.</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b-2 border-slate-200 dark:border-slate-600">
              <th class="text-left py-3 px-4 font-bold text-slate-700 dark:text-slate-300">Feature</th>
              <th class="text-center py-3 px-4 font-bold text-primary">FluentCards</th>
              <th class="text-center py-3 px-4 font-bold text-slate-500 dark:text-slate-400">Anki</th>
              <th class="text-center py-3 px-4 font-bold text-slate-500 dark:text-slate-400">Other Apps</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700 dark:text-slate-300">Price</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Free</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Free (desktop) / $25 (iOS)</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">$5-15/mo subscription</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700 dark:text-slate-300">Spaced Repetition Algorithm</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">FSRS-5 (neural network)</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">SM-2 / FSRS-5 (optional)</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Varies (often proprietary)</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700 dark:text-slate-300">Furigana Support</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Built-in</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Requires add-on</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Rarely available</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700 dark:text-slate-300">TTS Pronunciation</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Built-in (20+ languages)</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Requires add-on</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Often premium only</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700 dark:text-slate-300">AI Mnemonics</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Built-in (AI-generated)</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Not available</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Rarely available</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700 dark:text-slate-300">Cross-Device Sync</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Free (Firebase)</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Free (AnkiWeb)</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Usually included</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700 dark:text-slate-300">Community Marketplace</td>
              <td class="text-center py-3 px-4 text-primary font-bold">Built-in</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Shared decks (manual)</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Varies</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-slate-700 dark:text-slate-300">Import / Export</td>
              <td class="text-center py-3 px-4 text-primary font-bold">CSV, JSON</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">APKG</td>
              <td class="text-center py-3 px-4 text-slate-500 dark:text-slate-400">Varies</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mt-16 reveal-up delay-1">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-200 mb-6 text-center">Pricing FAQ</h2>
      <div class="space-y-0 divide-y divide-slate-200 dark:divide-slate-700">
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Will FluentCards ever introduce a paid plan?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">We have no plans to introduce paid plans. FluentCards is built on the belief that language learning tools should be free for everyone. If operating costs grow significantly, we would explore ways to cover them through ads or optional donations — never by locking features behind a paywall.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">How do you make money?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">We run non-intrusive advertisements through Google AdSense. These ads help cover hosting (Cloudflare Workers), database (Firebase), and API costs (AI image generation, TTS). We do not sell user data, and we do not run affiliate marketing schemes.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Are there any limits on flashcards or decks?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">No. You can create unlimited decks and unlimited flashcards. There are no storage caps, no card limits, and no artificial restrictions. The only limitation is the Firebase Firestore document size limit (1 MiB per document), which is generous enough for virtually all use cases.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">How does FluentCards compare to Anki?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Anki is a powerful tool, but it has a learning curve and requires add-ons for essential features like furigana and TTS. FluentCards includes these features out of the box with a modern interface. Both use FSRS, but FluentCards is free on all platforms — Anki costs $25 on iOS.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Can I use FluentCards offline?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Currently, FluentCards requires an internet connection to sync data and use features like TTS and AI mnemonics. Offline support with local caching is on the roadmap and will remain free when it ships.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">What happens if you can't cover costs anymore?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">If operating costs ever exceed what ads can cover, we would first explore cost optimization and optional donations before considering any changes to the free model. Users would be notified well in advance of any significant changes, and the community would have input on the direction.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="mt-16 text-center reveal-up">
      <p class="text-slate-500 dark:text-slate-400 mb-6">No catches. No trials. Just the best free flashcard app for language learners.</p>
      <a href="/app/" class="group inline-flex items-center gap-2.5 bg-primary text-white px-10 py-4 rounded-xl font-bold text-lg shadow-lg shadow-green-200 hover:shadow-xl hover:shadow-green-300 hover:bg-primary-hover active:scale-[0.97] transition-all duration-200">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Start Learning Free
      </a>
    </div>
  </div>

</main>

<Footer />

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal-up, .reveal-pop, .reveal-scale').forEach(el => observer.observe(el));
</script>
</body>
</html>
