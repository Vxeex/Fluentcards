---
import "../styles/main.css"
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
const currentPath = "/about/";
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About - FluentCards</title>
  <meta name="description" content="FluentCards is a free flashcard app for language learning with spaced repetition, furigana, and TTS. Learn about our mission to make language learning accessible for everyone." />
  <link rel="canonical" href="https://fluentcards.org/about/" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-sans text-slate-700 bg-white antialiased overflow-x-hidden">

<Nav currentPath={currentPath} />

<main class="pt-32 pb-20 px-6">
  <div class="max-w-2xl mx-auto">
    <div class="reveal-up">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 mb-3">About FluentCards</h1>
      <p class="text-lg text-slate-500 font-[500] mb-12">A flashcard app built for language learners, by language learners.</p>
    </div>

    <div class="space-y-8 reveal-up delay-1">
      <section>
        <h2 class="text-2xl font-bold text-slate-800 mb-3">Our Mission</h2>
        <p class="text-slate-500 leading-relaxed mb-4">
          FluentCards was created to make language learning more efficient and accessible.
          We believe that anyone can learn a new language with the right tools and consistent practice.
          Our goal is to provide a free, high-quality flashcard app that uses the latest research in
          spaced repetition to help you remember what you study.
        </p>
        <p class="text-slate-500 leading-relaxed">
          Unlike traditional flashcard apps that lock essential features behind subscriptions, FluentCards is
          free to use with no paywalls. All core features — spaced repetition, TTS, furigana, and AI mnemonics —
          are available to everyone without a subscription.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-slate-800 mb-3">Why We Built It</h2>
        <p class="text-slate-500 leading-relaxed mb-4">
          Many language learners rely on tools like Anki for spaced repetition, but the learning curve
          can be steep. We wanted something that worked out of the box — especially for Japanese learners
          who need furigana support, native TTS pronunciation, and AI-powered mnemonics.
        </p>
        <p class="text-slate-500 leading-relaxed">
          FluentCards started as a personal project and grew into a community tool. It supports multiple
          languages with a focus on Japanese, featuring automatic furigana rendering, Microsoft Edge TTS
          for natural pronunciation, and Gemini AI integration for generating memory aids.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-slate-800 mb-4">Our Values</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-slate-50 rounded-xl p-5 border border-slate-200">
            <div class="w-8 h-8 rounded-lg bg-primary-light flex items-center justify-center mb-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </div>
            <h3 class="text-base font-bold text-slate-800 mb-1">Free for Everyone</h3>
            <p class="text-sm text-slate-500 leading-relaxed">No subscriptions, no hidden fees. Language learning should be accessible to all.</p>
          </div>
          <div class="bg-slate-50 rounded-xl p-5 border border-slate-200">
            <div class="w-8 h-8 rounded-lg bg-primary-light flex items-center justify-center mb-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </div>
            <h3 class="text-base font-bold text-slate-800 mb-1">Open Standards</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Built on FSRS, the modern spaced repetition algorithm. Your data is yours.</p>
          </div>
          <div class="bg-slate-50 rounded-xl p-5 border border-slate-200">
            <div class="w-8 h-8 rounded-lg bg-primary-light flex items-center justify-center mb-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </div>
            <h3 class="text-base font-bold text-slate-800 mb-1">Privacy First</h3>
            <p class="text-sm text-slate-500 leading-relaxed">We use industry-standard encryption and never sell your personal data.</p>
          </div>
          <div class="bg-slate-50 rounded-xl p-5 border border-slate-200">
            <div class="w-8 h-8 rounded-lg bg-primary-light flex items-center justify-center mb-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </div>
            <h3 class="text-base font-bold text-slate-800 mb-1">Community Driven</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Share decks, discover content, and learn together through our marketplace.</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-slate-800 mb-3">Technology</h2>
        <p class="text-slate-500 leading-relaxed">
          FluentCards is built with <strong class="text-slate-700">Astro</strong> and <strong class="text-slate-700">React</strong>, styled with
          <strong class="text-slate-700">Tailwind CSS</strong>, and hosted on <strong class="text-slate-700">Cloudflare Workers</strong> for fast
          global performance. User data is stored securely in <strong class="text-slate-700">Firebase Firestore</strong>
          with Google Authentication. The spaced repetition engine uses the
          <strong class="text-slate-700">FSRS (Free Spaced Repetition Scheduler)</strong> algorithm.
        </p>
      </section>
    </div>
  </div>
</main>

<Footer />

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal-up').forEach(el => observer.observe(el));
</script>
</body>
</html>
