---
import "../styles/main.css"
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
import ThemeInit from "../components/ThemeInit.astro"
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <ThemeInit />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FluentCards - Free Anki Alternative for Language Learning (No Account Needed)</title>
  <meta name="description" content="FluentCards is a free flashcard app for learning Japanese, Korean, Spanish, and more. Features FSRS spaced repetition, furigana, TTS pronunciation, and AI mnemonics. No account required. A great Anki alternative." />
  <meta name="keywords" content="free flashcard app, language learning, spaced repetition app, anki alternative, japanese study, korean vocabulary, spanish flashcards, fsrs algorithm, furigana, tts pronunciation, best flashcard app, no account needed" />
  <link rel="canonical" href="https://fluentcards.org/" />
  <!-- Open Graph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="FluentCards - Free Flashcard App (No Account Needed)" />
  <meta property="og:description" content="FluentCards is a free flashcard app with FSRS spaced repetition, TTS pronunciation, furigana, and AI mnemonics. No account required. The best free Anki alternative." />
  <meta property="og:url" content="https://fluentcards.org/" />
  <meta property="og:site_name" content="FluentCards" />
  <meta property="og:image" content="https://fluentcards.org/images/app-screenshot.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="675" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://fluentcards.org/images/app-screenshot.jpg" />
  <meta name="twitter:title" content="FluentCards - Smart Flashcard App for Language Learning" />
  <meta name="twitter:description" content="Free flashcard app with spaced repetition for Japanese, Korean, Spanish, and more." />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "FluentCards",
    "url": "https://fluentcards.org/",
    "description": "Smart flashcard app for language learning with spaced repetition."
  }
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-sans text-slate-700 bg-white dark:bg-surface-dark dark:text-slate-400 antialiased overflow-x-hidden transition-colors duration-300">

<Nav currentPath={Astro.url.pathname} />

<!-- ========== What's New ========== -->
<section class="pt-24 pb-4 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="bg-gradient-to-r from-primary/5 via-white to-teal-400/5 dark:from-primary/10 dark:via-surface-dark dark:to-teal-400/5 rounded-2xl border border-primary/20 dark:border-emerald-900/30 p-4 sm:p-5 flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-6 reveal-up">
      <div class="flex items-center gap-2 shrink-0">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
        </span>
        <span class="text-xs font-bold uppercase tracking-wider text-primary">New This Week</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-4 text-sm min-w-0">
        <a href="/blog/beyond-the-textbook-polyglot-secrets/" class="group flex items-center gap-1.5 hover:text-primary transition-colors">
          <span class="px-1.5 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded uppercase">Blog</span>
          <span class="font-semibold text-slate-700 dark:text-slate-300 group-hover:text-primary truncate">Beyond the Textbook: Polyglot Secrets</span>
        </a>
        <span class="hidden sm:inline text-slate-300 dark:text-slate-600">·</span>
        <a href="/stories/frederick-douglass-reading/" class="group flex items-center gap-1.5 hover:text-primary transition-colors">
          <span class="px-1.5 py-0.5 bg-teal-400/10 text-teal-600 dark:text-teal-400 text-[10px] font-bold rounded uppercase">Story</span>
          <span class="font-semibold text-slate-700 dark:text-slate-300 group-hover:text-primary truncate">Frederick Douglass: Self-Taught to Change History</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ========== Hero ========== -->
<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-20">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-green-50 via-white to-emerald-50 dark:from-surface-dark dark:via-[#051510] dark:to-[#020a07] pointer-events-none"></div>

  <!-- Decorative gradient blobs -->
  <div class="absolute top-[-20%] right-[-10%] w-[600px] h-[600px] rounded-full bg-gradient-to-br from-primary/20 via-teal-400/10 to-transparent dark:from-primary/10 dark:via-emerald-800/10 dark:to-transparent blur-3xl animate-float pointer-events-none"></div>
  <div class="absolute bottom-[-10%] left-[-5%] w-[400px] h-[400px] rounded-full bg-gradient-to-tr from-teal-400/10 via-primary/5 to-transparent dark:from-emerald-800/10 dark:via-primary/5 dark:to-transparent blur-3xl animate-float pointer-events-none" style="animation-delay: -3s;"></div>

  <!-- Decorative cross-placed flashcards -->
  <div class="absolute left-[-8%] top-[12%] w-[180px] h-[250px] sm:w-[220px] sm:h-[300px] bg-white/70 dark:bg-white/10 backdrop-blur-md rounded-2xl border border-primary/20 dark:border-primary/15 shadow-xl shadow-primary/10 pointer-events-none hidden sm:block animate-card-sway" style="--rot: -12deg; animation-delay: -2s;">
    <div class="p-5 sm:p-6 flex flex-col gap-3">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary/30 to-teal-400/30"></div>
      <div class="h-2.5 w-full rounded-full bg-slate-300/50 dark:bg-slate-600/30"></div>
      <div class="h-2.5 w-3/4 rounded-full bg-slate-300/40 dark:bg-slate-600/20"></div>
      <div class="h-2.5 w-5/6 rounded-full bg-slate-300/40 dark:bg-slate-600/20"></div>
      <div class="mt-2 h-16 w-full rounded-lg bg-gradient-to-br from-primary/10 to-teal-400/10 border border-primary/10"></div>
      <div class="h-2 w-16 rounded-full bg-primary/20 mx-auto mt-1"></div>
    </div>
  </div>

  <div class="absolute right-[-8%] bottom-[18%] w-[160px] h-[220px] sm:w-[200px] sm:h-[270px] bg-white/70 dark:bg-white/10 backdrop-blur-md rounded-2xl border border-teal-400/20 dark:border-teal-400/15 shadow-xl shadow-teal-400/10 pointer-events-none hidden sm:block animate-card-sway" style="--rot: 8deg; animation-delay: -5s;">
    <div class="p-5 sm:p-6 flex flex-col gap-3">
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-amber-400/30 to-amber-600/30"></div>
        <div class="h-2 w-16 rounded-full bg-slate-300/40 dark:bg-slate-600/20"></div>
      </div>
      <div class="h-2.5 w-full rounded-full bg-slate-300/50 dark:bg-slate-600/30"></div>
      <div class="h-2.5 w-5/6 rounded-full bg-slate-300/40 dark:bg-slate-600/20"></div>
      <div class="mt-2 grid grid-cols-2 gap-2">
        <div class="h-10 rounded-lg bg-slate-300/20 dark:bg-slate-600/10"></div>
        <div class="h-10 rounded-lg bg-primary/10"></div>
      </div>
    </div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 bg-gradient-to-r from-primary/10 to-teal-400/10 text-primary px-5 py-1.5 rounded-full text-sm font-bold mb-6 border border-primary/20 backdrop-blur-sm animate-fade-in">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      Built for language learners
    </div>

    <h1 class="text-[3rem] sm:text-5xl lg:text-6xl xl:text-7xl font-black leading-[1.06] tracking-tight text-slate-900 dark:text-slate-100">
      The free Anki alternative<br class="hidden xs:inline" /> for <span class="bg-gradient-to-r from-primary via-primary to-teal-400 bg-clip-text text-transparent">smart</span> flashcards
    </h1>

    <p class="mt-6 text-xl sm:text-2xl text-slate-500 max-w-2xl mx-auto leading-relaxed font-[500]">
      FluentCards uses the FSRS spaced repetition algorithm to show you the right card at the right time — so you learn faster and remember longer. With furigana, TTS pronunciation, and AI mnemonics.
    </p>

    <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
      <a href="/app/" class="group inline-flex items-center gap-2.5 bg-primary text-white px-8 py-4 rounded-2xl font-bold text-base shadow-xl shadow-primary/25 hover:shadow-2xl hover:shadow-primary/40 hover:bg-primary-hover active:scale-[0.97] transition-all duration-200 animate-glow">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Start Learning Free
      </a>
      <a href="/features/" class="inline-flex items-center gap-2 bg-white text-slate-700 dark:bg-surface-card dark:text-slate-300 px-8 py-4 rounded-2xl font-bold text-base border-2 border-primary/20 dark:border-emerald-900/30 shadow-sm hover:border-primary hover:text-primary active:scale-[0.97] transition-all duration-200">
        See Features
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m7 15 5-5 5 5"/></svg>
      </a>
    </div>

    <!-- App screenshot -->
    <div class="mt-16 max-w-4xl mx-auto px-4 reveal-up">
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-b from-primary/10 to-transparent dark:from-primary/5 rounded-[24px] blur-2xl pointer-events-none"></div>
        <!-- Device frame -->
        <div class="relative bg-slate-50 dark:bg-slate-900 rounded-[24px] shadow-2xl shadow-primary/15 dark:shadow-primary/10 p-3">
          <!-- Browser bar -->
          <div class="flex items-center gap-2 px-3 pb-3">
            <div class="w-3 h-3 rounded-full bg-rose-400"></div>
            <div class="w-3 h-3 rounded-full bg-amber-400"></div>
            <div class="w-3 h-3 rounded-full bg-emerald-400"></div>
            <div class="ml-3 h-5 flex-1 max-w-[180px] rounded-md bg-slate-200 dark:bg-slate-700"></div>
          </div>
          <!-- Screenshot -->
          <div class="rounded-[16px] overflow-hidden">
            <img
              src="/images/app-screenshot.jpg"
              alt="FluentCards flashcard app showing vocabulary decks and study interface"
              class="w-full h-auto block"
              loading="lazy"
              width="1200"
              height="675"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-white to-transparent dark:from-surface-dark pointer-events-none"></div>
</section>

<!-- ========== Trust Signals ========== -->
<section class="py-16 sm:py-20 px-6 bg-gradient-to-b from-white to-green-50/30 dark:from-surface-dark dark:to-[#051510]">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-5">
      <div class="bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-5 sm:p-6 border border-primary/10 dark:border-emerald-900/30 text-center hover:shadow-lg hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-1 transition-all duration-300 reveal-pop delay-1">
        <div class="text-2xl sm:text-3xl font-black text-primary mb-1">20+</div>
        <p class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 font-medium">Languages</p>
      </div>
      <div class="bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-5 sm:p-6 border border-primary/10 dark:border-emerald-900/30 text-center hover:shadow-lg hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-1 transition-all duration-300 reveal-pop delay-2">
        <div class="text-2xl sm:text-3xl font-black text-primary mb-1">0</div>
        <p class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 font-medium">Ads in app</p>
      </div>
      <div class="bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-5 sm:p-6 border border-primary/10 dark:border-emerald-900/30 text-center hover:shadow-lg hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-1 transition-all duration-300 reveal-pop delay-3">
        <div class="text-2xl sm:text-3xl font-black text-primary mb-1">50+</div>
        <p class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 font-medium">Countries</p>
      </div>
      <div class="bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-5 sm:p-6 border border-primary/10 dark:border-emerald-900/30 text-center hover:shadow-lg hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-1 transition-all duration-300 reveal-pop delay-4">
        <div class="text-2xl sm:text-3xl font-black text-primary mb-1">$0</div>
        <p class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 font-medium">Free forever</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== Features ========== -->
<section class="py-24 sm:py-32 px-6 bg-gradient-to-b from-green-50/50 to-white dark:from-surface-dark dark:to-[#051510] border-y border-primary/10 dark:border-emerald-900/20">
  <div class="max-w-6xl mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-16 reveal-up">
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-slate-900 via-slate-800 to-primary/80 dark:from-slate-100 dark:via-slate-300 dark:to-primary bg-clip-text text-transparent">Everything you need to learn</h2>
      <p class="mt-4 text-lg text-slate-500 font-[500]">Powerful tools built for serious language learners, from beginner to advanced.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <!-- Feature 1 -->
      <a href="/science/" class="group bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-8 border border-primary/10 dark:border-emerald-900/30 hover:border-primary/30 dark:hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-2 transition-all duration-300 reveal-pop delay-1">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-emerald-600 flex items-center justify-center text-white shadow-md shadow-primary/20 mb-5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <h3 class="text-lg font-extrabold text-slate-800 dark:text-slate-200 mb-1.5">Spaced Repetition (FSRS)</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Advanced algorithm schedules reviews at optimal intervals so you remember more with less effort.</p>
      </a>

      <!-- Feature 2 -->
      <a href="/blog/furigana-guide/" class="group bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-8 border border-primary/10 dark:border-emerald-900/30 hover:border-primary/30 dark:hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-2 transition-all duration-300 reveal-pop delay-2">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-emerald-600 flex items-center justify-center text-white shadow-md shadow-primary/20 mb-5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <h3 class="text-lg font-extrabold text-slate-800 dark:text-slate-200 mb-1.5">Furigana Support</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Automatically adds reading aids to Japanese text. Just type 漢字[かんじ] and it renders beautifully with ruby annotations.</p>
      </a>

      <!-- Feature 3 -->
      <a href="/blog/japanese-pronunciation-guide/" class="group bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-8 border border-primary/10 dark:border-emerald-900/30 hover:border-primary/30 dark:hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-2 transition-all duration-300 reveal-pop delay-3">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-emerald-600 flex items-center justify-center text-white shadow-md shadow-primary/20 mb-5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 8 14 13 10 16 6 4 9 3 18 0 12 8"/><path d="M20 11v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-6"/></svg>
        </div>
        <h3 class="text-lg font-extrabold text-slate-800 dark:text-slate-200 mb-1.5">Native TTS Pronunciation</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Hear correct pronunciation with Microsoft Edge TTS engine. Adjust speed and auto-play on cards.</p>
      </a>

      <!-- Feature 4 -->
      <a href="/blog/bizarre-mnemonics/" class="group bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-8 border border-primary/10 dark:border-emerald-900/30 hover:border-primary/30 dark:hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-2 transition-all duration-300 reveal-pop delay-1">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-emerald-600 flex items-center justify-center text-white shadow-md shadow-primary/20 mb-5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-1.04A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-1.04A2.5 2.5 0 0 0 14.5 2Z"/></svg>
        </div>
        <h3 class="text-lg font-extrabold text-slate-800 dark:text-slate-200 mb-1.5">AI Mnemonics</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">AI generates visual memory aids to help you remember difficult words and characters.</p>
      </a>

      <!-- Feature 5 -->
      <a href="/pricing/" class="group bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-8 border border-primary/10 dark:border-emerald-900/30 hover:border-primary/30 dark:hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-2 transition-all duration-300 reveal-pop delay-2">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-emerald-600 flex items-center justify-center text-white shadow-md shadow-primary/20 mb-5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h3 class="text-lg font-extrabold text-slate-800 dark:text-slate-200 mb-1.5">Review History</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Track your progress with FSRS metrics — stability, difficulty, and retention over time.</p>
      </a>

      <!-- Feature 6 -->
      <a href="/app/#/discover" class="group bg-white/80 dark:bg-surface-card/80 backdrop-blur-sm rounded-2xl p-8 border border-primary/10 dark:border-emerald-900/30 hover:border-primary/30 dark:hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/10 dark:hover:shadow-primary/5 hover:-translate-y-2 transition-all duration-300 reveal-pop delay-3">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-emerald-600 flex items-center justify-center text-white shadow-md shadow-primary/20 mb-5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m8 14 4-4 4 4"/></svg>
        </div>
        <h3 class="text-lg font-extrabold text-slate-800 dark:text-slate-200 mb-1.5">Community Marketplace</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Discover shared decks made by other learners. Clone them to your library instantly.</p>
      </a>
    </div>
  </div>
</section>

<!-- ========== How It Works ========== -->
<section class="py-24 sm:py-32 px-6 bg-gradient-to-b from-white via-green-50/30 to-white dark:from-surface-dark dark:via-[#051510] dark:to-surface-dark">
  <div class="max-w-3xl mx-auto">
    <div class="text-center max-w-xl mx-auto mb-16 reveal-up">
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-slate-900 via-slate-800 to-primary/80 dark:from-slate-100 dark:via-slate-300 dark:to-primary bg-clip-text text-transparent">How It Works</h2>
      <p class="mt-4 text-lg text-slate-500 font-[500]">Three simple steps to start learning effectively.</p>
    </div>

    <div class="relative">
      <!-- Connecting line -->
      <div class="absolute left-[31px] top-0 bottom-0 w-[3px] bg-gradient-to-b from-primary via-primary/40 to-transparent hidden sm:block"></div>

      <!-- Step 1 -->
      <div class="relative flex gap-6 mb-14 reveal-up">
        <div class="relative z-10 w-16 h-16 rounded-2xl bg-gradient-to-br from-primary to-emerald-600 flex items-center justify-center text-white font-black text-xl shadow-lg shadow-primary/20 flex-shrink-0">1</div>
        <div class="pt-2">
          <h3 class="text-xl font-black text-slate-800 dark:text-slate-200 mb-2">Create a deck</h3>
