---
import "../styles/main.css"
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us - FluentCards</title>
  <meta name="description" content="Contact the FluentCards team. Get support for our flashcard app, send feedback, ask questions about spaced repetition or Japanese learning, or report issues." />
  <link rel="canonical" href="https://fluentcards.org/contact/" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is FluentCards really free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. FluentCards is completely free to use. There are no subscription plans, premium tiers, or hidden charges."
        }
      },
      {
        "@type": "Question",
        "name": "How is my data protected?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We use Firebase Authentication for secure login and Firebase Firestore for encrypted data storage. Your flashcard data is private by default and only shared if you choose to publish a deck to the marketplace."
        }
      },
      {
        "@type": "Question",
        "name": "Can I delete my account?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Contact us at privacy@fluentcards.org and we will delete your account and all associated data."
        }
      },
      {
        "@type": "Question",
        "name": "Which languages are supported?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "FluentCards supports any language for flashcards. For Japanese, we offer special features like automatic furigana rendering and native TTS pronunciation."
        }
      },
      {
        "@type": "Question",
        "name": "Can I share my decks with others?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You can mark a deck as Public in the deck settings, and it will appear in the Discover section where other users can clone it."
        }
      }
    ]
  }
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-body bg-cream text-ink-900 antialiased overflow-x-hidden">

<Nav currentPath="/contact/" />

<main class="pt-32 pb-20 px-6">
  <div class="max-w-2xl mx-auto">
    <div class="reveal-up">
      <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-ink-900 mb-3">Contact Us</h1>
      <p class="text-lg text-ink-500 font-[500] mb-12">Have a question or feedback? We'd love to hear from you.</p>
    </div>

    <div class="space-y-4 reveal-up delay-1">
      <div class="bg-white rounded-xl p-6 border border-parchment-200 flex items-start gap-4">
        <div class="w-11 h-11 rounded-lg bg-cinnabar-100 flex items-center justify-center shrink-0 text-xl">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cinnabar-500"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </div>
        <div>
          <h3 class="font-display text-base font-bold text-ink-800 mb-1">Email</h3>
          <p class="text-sm text-ink-500 mb-1"><a href="mailto:support@fluentcards.org" class="text-cinnabar-500 hover:text-cinnabar-600 underline underline-offset-2">support@fluentcards.org</a></p>
          <p class="text-sm text-ink-400">For general inquiries, support requests, and feedback. We typically respond within 24 hours.</p>
        </div>
      </div>

      <div class="bg-white rounded-xl p-6 border border-parchment-200 flex items-start gap-4">
        <div class="w-11 h-11 rounded-lg bg-slateblue-100 flex items-center justify-center shrink-0 text-xl">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slateblue-500"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div>
          <h3 class="font-display text-base font-bold text-ink-800 mb-1">Privacy Concerns</h3>
          <p class="text-sm text-ink-500 mb-1"><a href="mailto:privacy@fluentcards.org" class="text-cinnabar-500 hover:text-cinnabar-600 underline underline-offset-2">privacy@fluentcards.org</a></p>
          <p class="text-sm text-ink-400">For questions about your data, account deletion requests, or privacy-related matters.</p>
        </div>
      </div>

      <div class="bg-white rounded-xl p-6 border border-parchment-200 flex items-start gap-4">
        <div class="w-11 h-11 rounded-lg bg-gold-100 flex items-center justify-center shrink-0 text-xl">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-600"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </div>
        <div>
          <h3 class="font-display text-base font-bold text-ink-800 mb-1">Bug Reports</h3>
          <p class="text-sm text-ink-400">Found a bug? Describe what happened and what you were doing. Screenshots are helpful too.</p>
        </div>
      </div>

      <div class="bg-white rounded-xl p-6 border border-parchment-200 flex items-start gap-4">
        <div class="w-11 h-11 rounded-lg bg-cinnabar-100 flex items-center justify-center shrink-0 text-xl">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cinnabar-500"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-1.04A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-1.04A2.5 2.5 0 0 0 14.5 2Z"/></svg>
        </div>
        <div>
          <h3 class="font-display text-base font-bold text-ink-800 mb-1">Feature Requests</h3>
          <p class="text-sm text-ink-400">Have an idea to make FluentCards better? We're always open to suggestions from our community.</p>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <section class="mt-16 reveal-up delay-2">
      <h2 class="font-display text-2xl font-bold text-ink-800 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-0 divide-y divide-parchment-200">
        <div class="py-5">
          <h3 class="font-display text-base font-bold text-ink-800 mb-2">Is FluentCards really free?</h3>
          <p class="text-sm text-ink-500 leading-relaxed">Yes. FluentCards is completely free to use. There are no subscription plans, premium tiers, or hidden charges.</p>
        </div>
        <div class="py-5">
          <h3 class="font-display text-base font-bold text-ink-800 mb-2">How is my data protected?</h3>
          <p class="text-sm text-ink-500 leading-relaxed">We use Firebase Authentication for secure login and Firebase Firestore for encrypted data storage. Your flashcard data is private by default and only shared if you choose to publish a deck to the marketplace.</p>
        </div>
        <div class="py-5">
          <h3 class="font-display text-base font-bold text-ink-800 mb-2">Can I delete my account?</h3>
          <p class="text-sm text-ink-500 leading-relaxed">Yes. Contact us at <a href="mailto:privacy@fluentcards.org" class="text-cinnabar-500 underline underline-offset-2">privacy@fluentcards.org</a> and we'll delete your account and all associated data.</p>
        </div>
        <div class="py-5">
          <h3 class="font-display text-base font-bold text-ink-800 mb-2">Which languages are supported?</h3>
          <p class="text-sm text-ink-500 leading-relaxed">FluentCards supports any language for flashcards. For Japanese, we offer special features like automatic furigana rendering and native TTS pronunciation. Additional language-specific features are coming soon.</p>
        </div>
        <div class="py-5">
          <h3 class="font-display text-base font-bold text-ink-800 mb-2">Can I share my decks with others?</h3>
          <p class="text-sm text-ink-500 leading-relaxed">Yes. You can mark a deck as "Public" in the deck settings, and it will appear in the Discover section where other users can clone it.</p>
        </div>
      </div>
    </section>
  </div>
</main>

<Footer />

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal-up').forEach(el => observer.observe(el));
</script>
</body>
</html>
