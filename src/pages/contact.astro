---
import "../styles/main.css"
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
import ThemeInit from "../components/ThemeInit.astro"
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <ThemeInit />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us - FluentCards Support & Frequently Asked Questions</title>
  <meta name="description" content="Contact the FluentCards team for support, feedback, or questions. Comprehensive FAQ covering accounts, data privacy, flashcards, TTS, and more. We typically respond within 24 hours." />
  <link rel="canonical" href="https://fluentcards.org/contact/" />
  <!-- Open Graph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Contact Us - FluentCards Support & Frequently Asked Questions" />
  <meta property="og:description" content="Contact the FluentCards team for support, feedback, or questions. Comprehensive FAQ covering accounts, data privacy, flashcards, TTS, and more." />
  <meta property="og:url" content="https://fluentcards.org/contact/" />
  <meta property="og:site_name" content="FluentCards" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Contact Us - FluentCards Support & Frequently Asked Questions" />
  <meta name="twitter:description" content="Contact the FluentCards team for support, feedback, or questions." />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is FluentCards really free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. FluentCards is completely free to use. There are no subscription plans, premium tiers, or hidden charges."
        }
      },
      {
        "@type": "Question",
        "name": "How is my data protected?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We use Firebase Authentication for secure login and Firebase Firestore for encrypted data storage. Your flashcard data is private by default and only shared if you choose to publish a deck to the marketplace."
        }
      },
      {
        "@type": "Question",
        "name": "Can I delete my account?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Contact us at vxeexvxeex@gmail.com and we will delete your account and all associated data."
        }
      },
      {
        "@type": "Question",
        "name": "Which languages are supported?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "FluentCards supports any language for flashcards. For Japanese, we offer special features like automatic furigana rendering and native TTS pronunciation."
        }
      },
      {
        "@type": "Question",
        "name": "Can I share my decks with others?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You can mark a deck as Public in the deck settings, and it will appear in the Discover section where other users can clone it."
        }
      },
      {
        "@type": "Question",
        "name": "How do I enable AI mnemonics?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "When creating or editing a flashcard, toggle the AI mnemonic option. AI will generate a visual memory aid for that card. You can enable it per card or for all cards in a deck."
        }
      },
      {
        "@type": "Question",
        "name": "How does the spaced repetition algorithm work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "FluentCards uses FSRS-5, which tracks three metrics per card: Stability (how long the memory lasts), Difficulty (how hard the card is), and Retrievability (probability of recall). Reviews are scheduled when Retrievability drops below a threshold."
        }
      },
      {
        "@type": "Question",
        "name": "Can I import cards from Anki?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can import flashcards via CSV or JSON format. Anki can export decks to CSV, which you can then import into FluentCards. See our guide for detailed instructions."
        }
      },
      {
        "@type": "Question",
        "name": "Does FluentCards have a mobile app?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "FluentCards is a web app that works on mobile browsers. You can add it to your home screen for an app-like experience. A native mobile app is being considered for the future."
        }
      },
      {
        "@type": "Question",
        "name": "How do I report a bug?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Email us at vxeexvxeex@gmail.com with a description of the bug, steps to reproduce it, and your browser/device information. Screenshots are very helpful."
        }
      }
    ]
  }
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-sans text-slate-700 bg-white dark:bg-slate-950 dark:text-slate-400 antialiased overflow-x-hidden transition-colors duration-300">

<Nav currentPath="/contact/" />

<main class="pt-32 pb-20 px-6">
  <div class="max-w-2xl mx-auto">
    <div class="reveal-up">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100 mb-3">Contact Us</h1>
      <p class="text-lg text-slate-500 font-[500] mb-4">Have a question or feedback? We'd love to hear from you.</p>
      <p class="text-sm text-slate-400 mb-12">We typically respond within 24 hours. For faster help, check the FAQ below — your question may already be answered.</p>
    </div>

    <!-- Contact Methods -->
    <div class="space-y-4 reveal-up delay-1">
      <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-600 flex items-start gap-4 hover:shadow-sm transition-shadow">
        <div class="w-11 h-11 rounded-lg bg-primary-light flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </div>
        <div>
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-1">General Support & Feedback</h3>
          <p class="text-sm text-slate-500 mb-1"><a href="mailto:vxeexvxeex@gmail.com" class="text-primary hover:text-primary-hover underline underline-offset-2">vxeexvxeex@gmail.com</a></p>
          <p class="text-sm text-slate-400">For general inquiries, support requests, feature suggestions, and feedback. We read every message and respond within 24 hours on weekdays.</p>
        </div>
      </div>

      <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-600 flex items-start gap-4 hover:shadow-sm transition-shadow">
        <div class="w-11 h-11 rounded-lg bg-primary-light flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div>
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-1">Privacy & Account Concerns</h3>
          <p class="text-sm text-slate-500 mb-1"><a href="mailto:vxeexvxeex@gmail.com" class="text-primary hover:text-primary-hover underline underline-offset-2">vxeexvxeex@gmail.com</a></p>
          <p class="text-sm text-slate-400">For account deletion requests, data access inquiries, or any privacy-related questions. We handle these requests within 48 hours.</p>
        </div>
      </div>

      <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-600 flex items-start gap-4 hover:shadow-sm transition-shadow">
        <div class="w-11 h-11 rounded-lg bg-primary-light flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </div>
        <div>
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-1">Bug Reports</h3>
          <p class="text-sm text-slate-400">Found something broken? Please include what you were doing, what you expected to happen, and what actually happened. Browser, device, and OS details help us fix it faster. Screenshots or screen recordings are always appreciated.</p>
        </div>
      </div>

      <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-600 flex items-start gap-4 hover:shadow-sm transition-shadow">
        <div class="w-11 h-11 rounded-lg bg-primary-light flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-1.04A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-1.04A2.5 2.5 0 0 0 14.5 2Z"/></svg>
        </div>
        <div>
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-1">Feature Requests</h3>
          <p class="text-sm text-slate-400">Have an idea to make FluentCards better? We maintain a public feature roadmap and prioritize based on community demand. Tell us what you'd like to see — if it helps other learners too, we'll likely build it.</p>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <section class="mt-16 reveal-up delay-2">
      <h2 class="text-2xl font-bold text-slate-800 dark:text-slate-200 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-0 divide-y divide-slate-200 dark:divide-slate-700">
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Is FluentCards really free?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Yes. FluentCards is completely free to use. There are no subscription plans, premium tiers, or hidden charges. All features — FSRS spaced repetition, TTS pronunciation, furigana support, AI mnemonics, and the marketplace — are available to everyone at no cost.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">How is my data protected?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">We use Firebase Authentication for secure login and Firebase Firestore for encrypted data storage. Your flashcard data is private by default and only shared if you explicitly choose to publish a deck to the marketplace. We never sell or share personal data with third parties.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Can I delete my account and data?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Yes. Contact us at <a href="mailto:vxeexvxeex@gmail.com" class="text-primary underline underline-offset-2">vxeexvxeex@gmail.com</a> and we will permanently delete your account and all associated data within 48 hours. This includes all decks, flashcards, review history, and personal information.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Which languages are supported?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">FluentCards supports any language for flashcards. For Japanese, we offer automatic furigana rendering and native TTS pronunciation. TTS supports 20+ languages including Japanese, Korean, Chinese, Spanish, French, German, Italian, Portuguese, Russian, and more. Each language uses region-specific neural voices.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Can I share my decks with others?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Yes. You can mark a deck as "Public" in the deck settings, and it will appear in the Discover section where other users can view and clone it. You can also keep decks private for personal use. Public decks can be made private again at any time.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">How do I enable AI mnemonics?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">When creating or editing a flashcard, toggle the AI mnemonic option (the sparkle icon). AI will generate a visual memory aid for that card. You can enable it per card or use the bulk toggle for all cards in a deck. AI mnemonics work best for concrete vocabulary but can help with abstract concepts too.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">How does the FSRS spaced repetition algorithm work?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">FluentCards uses FSRS-5, a modern algorithm trained on millions of real review logs. It tracks three metrics for each card: <strong class="text-slate-700 dark:text-slate-300">Stability</strong> (how long the memory lasts — measured in days), <strong class="text-slate-700 dark:text-slate-300">Difficulty</strong> (how inherently hard the card is), and <strong class="text-slate-700 dark:text-slate-300">Retrievability</strong> (the probability you'll remember it today). Reviews are scheduled when Retrievability drops below a set threshold, and your rating (Again/Hard/Good/Easy) updates the algorithm for future scheduling. <a href="/blog/fsrs-spaced-repetition-algorithm/" class="text-primary underline underline-offset-2">Learn more about FSRS</a>.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Can I import cards from Anki or other apps?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Yes. FluentCards supports import from CSV and JSON formats. Anki can export decks to CSV (File → Export → Notes in Plain Text format). You can then import the CSV file into FluentCards. For other apps, check if they support CSV export — most do. <a href="/blog/japanese-flashcard-study-guide/" class="text-primary underline underline-offset-2">See our study guide</a> for detailed import instructions.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Does FluentCards have a mobile app?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">FluentCards is a responsive web app that works on all mobile browsers. You can add it to your phone's home screen for an app-like experience (tap Share → Add to Home Screen on iOS, or the menu → Add to Home Screen on Android). A native mobile app is on the roadmap for future development.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">How do I report a bug?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Email us at <a href="mailto:vxeexvxeex@gmail.com" class="text-primary underline underline-offset-2">vxeexvxeex@gmail.com</a> with a description of the bug. Please include: what you were doing when it happened, what you expected to happen, what actually happened, and your browser and device information. Screenshots or screen recordings help us fix issues faster.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">Do you support furigana for languages other than Japanese?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">The furigana (ruby annotation) system works for any language, but it's most useful for Japanese kanji. You can use the bracket syntax <code class="bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300 px-1 py-0.5 rounded text-xs font-semibold">文字[もじ]</code> to add reading aids to any text. For Chinese pinyin or Korean hangul guides, the same syntax works.</p>
        </div>
        <div class="py-5">
          <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2">How do I change the TTS voice or speed?</h3>
          <p class="text-sm text-slate-500 leading-relaxed">When studying a deck, tap the settings icon in the study view. You can adjust the speech rate from 0.5x (slow) to 2.0x (fast). The TTS voice is automatically selected based on the language you set for each card. You can change the language for individual cards in the card editor.</p>
        </div>
      </div>

      <div class="mt-8 bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-600 text-center">
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Still have questions?</p>
        <p class="text-sm text-slate-500 dark:text-slate-400">Email us at <a href="mailto:vxeexvxeex@gmail.com" class="text-primary font-semibold underline underline-offset-2">vxeexvxeex@gmail.com</a> and we'll get back to you within 24 hours.</p>
      </div>
    </section>

    <!-- Back -->
    <div class="mt-12 text-center reveal-up">
      <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 hover:text-primary transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to FluentCards
      </a>
    </div>
  </div>
</main>

<Footer />

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal-up').forEach(el => observer.observe(el));
</script>
</body>
</html>
