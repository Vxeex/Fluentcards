      <!-- Tips -->
      <a href="/blog/best-way-to-learn-japanese-vocabulary/" class="group bg-white rounded-xl border border-parchment-200 p-6 hover:border-gold-300 hover:-translate-y-1 hover:shadow-sm transition-all duration-300 reveal-up delay-2">
