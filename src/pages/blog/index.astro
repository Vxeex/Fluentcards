      <!-- Tech -->
      <a href="/blog/fsrs-spaced-repetition-algorithm/" class="group bg-white rounded-xl border border-parchment-200 p-6 hover:border-slateblue-300 hover:-translate-y-1 hover:shadow-sm transition-all duration-300 reveal-up delay-3">
