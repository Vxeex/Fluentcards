---
import "../../styles/main.css"
import Nav from "../../components/Nav.astro"
import Footer from "../../components/Footer.astro"
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog & Guides - FluentCards Language Learning Resources</title>
  <meta name="description" content="Learn how to study languages effectively with flashcards and spaced repetition. Guides for Japanese, Korean, Spanish, kanji, vocabulary, pronunciation, and flashcard study techniques." />
  <meta name="keywords" content="language learning blog, japanese study guide, korean vocabulary, spanish flashcards, spaced repetition tutorial, flashcard tips, learn languages" />
  <link rel="canonical" href="https://fluentcards.org/blog/" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-body bg-cream text-ink-900 antialiased overflow-x-hidden">

<Nav currentPath="/blog/" />

<!-- Header -->
<section class="pt-32 pb-16 px-6 text-center">
  <div class="max-w-2xl mx-auto reveal-up">
    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-ink-900">Language Learning Guides</h1>
    <p class="mt-4 text-lg text-ink-500 font-[500] leading-relaxed">Practical guides to help you learn languages more effectively with flashcards and spaced repetition.</p>
  </div>
</section>

<!-- Blog Grid -->
<section class="pb-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

      <!-- Guide -->
      <a href="/blog/japanese-flashcard-study-guide/" class="group bg-white rounded-xl border border-parchment-200 p-6 hover:border-cinnabar-200 hover:-translate-y-1 hover:shadow-sm transition-all duration-300 reveal-up delay-1">
        <span class="inline-block bg-cinnabar-50 text-cinnabar-600 px-3 py-0.5 rounded-full text-xs font-bold mb-4 border border-cinnabar-100">Guide</span>
        <h2 class="font-display text-base font-bold text-ink-800 mb-2 leading-snug group-hover:text-cinnabar-500 transition-colors">Japanese Flashcard Study Guide: How to Learn with Flashcards</h2>
        <p class="text-sm text-ink-500 leading-relaxed mb-4 line-clamp-2">A complete step-by-step guide to studying Japanese using digital flashcards. From setup to daily routine, learn the most effective approach.</p>
        <span class="text-xs text-ink-400 font-semibold">8 min read</span>
      </a>

      <!-- Basics -->
      <a href="/blog/how-to-use-spaced-repetition/" class="group bg-white rounded-xl border border-parchment-200 p-6 hover:border-gold-300 hover:-translate-y-1 hover:shadow-sm transition-all duration-300 reveal-up delay-2">
        <span class="inline-block bg-gold-50 text-gold-700 px-3 py-0.5 rounded-full text-xs font-bold mb-4 border border-gold-100">Basics</span>
        <h2 class="font-display text-base font-bold text-ink-800 mb-2 leading-snug group-hover:text-gold-600 transition-colors">How to Use Spaced Repetition for Language Learning</h2>
        <p class="text-sm text-ink-500 leading-relaxed mb-4 line-clamp-2">Understand the science behind spaced repetition and how to apply it to memorize vocabulary, kanji, grammar, and more.</p>
        <span class="text-xs text-ink-400 font-semibold">7 min read</span>
      </a>

      <!-- Japanese -->
      <a href="/blog/learn-japanese-kanji-with-flashcards/" class="group bg-white rounded-xl border border-parchment-200 p-6 hover:border-cinnabar-200 hover:-translate-y-1 hover:shadow-sm transition-all duration-300 reveal-up delay-3">
        <span class="inline-block bg-cinnabar-50 text-cinnabar-600 px-3 py-0.5 rounded-full text-xs font-bold mb-4 border border-cinnabar-100">Japanese</span>
