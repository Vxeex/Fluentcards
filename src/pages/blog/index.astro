---
import "../../styles/main.css"
import Nav from "../../components/Nav.astro"
import Footer from "../../components/Footer.astro"
import ThemeInit from "../../components/ThemeInit.astro"
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <ThemeInit />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog & Guides - FluentCards Language Learning Resources</title>
  <meta name="description" content="Learn how to study languages effectively with flashcards and spaced repetition. Guides for Japanese, Korean, Spanish, kanji, vocabulary, pronunciation, and flashcard study techniques." />
  <meta name="keywords" content="language learning blog, japanese study guide, korean vocabulary, spanish flashcards, spaced repetition tutorial, flashcard tips, learn languages" />
  <link rel="canonical" href="https://fluentcards.org/blog/" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-sans text-slate-700 bg-white dark:bg-slate-950 dark:text-slate-400 antialiased overflow-x-hidden transition-colors duration-300">

<Nav currentPath="/blog/" />

<!-- Header -->
<section class="pt-32 pb-16 px-6 text-center">
  <div class="max-w-2xl mx-auto reveal-up">
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">Language Learning Guides</h1>
    <p class="mt-4 text-lg text-slate-500 font-[500] leading-relaxed">Practical guides to help you learn languages more effectively with flashcards and spaced repetition.</p>
  </div>
</section>

<!-- Blog Grid -->
<section class="pb-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

      <!-- The Language Reflex (top, newest) -->
      <a href="/blog/the-language-reflex/" class="group bg-white dark:bg-slate-800 rounded-xl border-2 border-primary/30 p-6 hover:border-primary hover:-translate-y-1 hover:shadow-md transition-all duration-300 reveal-up delay-1 relative">
        <span class="absolute -top-2.5 -right-2.5 bg-primary text-white text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-wider">New</span>
        <span class="inline-block bg-primary text-white px-3 py-0.5 rounded-full text-xs font-bold mb-4">Guide</span>
        <h2 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2 leading-snug group-hover:text-primary transition-colors">The Language Reflex: Why Your Brain Is a Slow Translator (and How to Fix It)</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-4 line-clamp-2">Stop translating in your head. Based on CIA and FSI training methodology, learn pattern drills, the 2-second rule, and the 14-day protocol to build a true language reflex.</p>
        <span class="text-xs text-slate-400 font-semibold">14 min read</span>
      </a>

      <!-- Beyond the Textbook -->
      <a href="/blog/beyond-the-textbook-polyglot-secrets/" class="group bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-600 p-6 hover:border-primary/40 hover:-translate-y-1 hover:shadow-sm transition-all duration-300 reveal-up delay-1">
        <span class="inline-block bg-primary-light text-primary px-3 py-0.5 rounded-full text-xs font-bold mb-4 border border-primary-light">Guide</span>
        <h2 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-2 leading-snug group-hover:text-primary transition-colors">Beyond the Textbook: 5 Counter-Intuitive Secrets from the World's Greatest Polyglots and Spies</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-4 line-clamp-2">Elite linguists from Kato Lomb to intelligence operatives share counter-intuitive techniques: pattern drills, multi-sensory overload, and the no-translation rule for rapid fluency.</p>
        <span class="text-xs text-slate-400 font-semibold">12 min read</span>
