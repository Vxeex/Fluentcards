---
import "../styles/main.css"
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
import ThemeInit from "../components/ThemeInit.astro"

export interface Props {
  title: string;
  description: string;
  canonical: string;
  headline: string;
  readTime: string;
  difficulty: string;
  sections: number;
}

const { title, description, canonical, headline, readTime, difficulty, sections } = Astro.props;
const fullUrl = `https://fluentcards.org${canonical}`;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <ThemeInit />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullUrl} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={headline} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={fullUrl} />
  <meta property="og:site_name" content="FluentCards" />
  <meta property="og:image" content="https://fluentcards.org/images/app-screenshot.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="675" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://fluentcards.org/images/app-screenshot.jpg" />
  <meta name="twitter:title" content={headline} />
  <meta name="twitter:description" content={description} />
  <script type="application/ld+json">
  {JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "headline": headline,
    "description": description,
    "author": { "@type": "Organization", "name": "FluentCards" },
    "publisher": { "@type": "Organization", "name": "FluentCards", "url": "https://fluentcards.org" },
    "mainEntityOfPage": fullUrl
  })}
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-sans text-slate-700 bg-white dark:bg-surface-dark dark:text-slate-400 antialiased overflow-x-hidden transition-colors duration-300">

<Nav currentPath="/guides/" />

<main class="pt-32 pb-16 px-6">
  <article class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="mb-10 reveal-up">
      <span class="inline-block bg-gradient-to-r from-primary/20 to-teal-400/20 text-primary px-3.5 py-1 rounded-full text-xs font-bold mb-4 border border-primary/20">Guide</span>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100 leading-tight">{headline}</h1>
      <div class="mt-4 flex items-center gap-4 text-sm text-slate-400 flex-wrap">
        <span class="flex items-center gap-1"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> {readTime}</span>
        <span class="flex items-center gap-1"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 12 8 12 8"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 12 8 12 8"/><path d="M4 22h16"/><path d="M10 22V8"/><path d="M14 22V8"/></svg> {difficulty}</span>
        <span class="flex items-center gap-1"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg> {sections} sections</span>
      </div>
    </div>

    <!-- Content -->
    <div class="article-body">
      <slot />
    </div>

    <!-- CTA -->
    <div class="mt-12 bg-gradient-to-br from-primary/10 to-teal-400/10 dark:from-primary/5 dark:to-teal-400/5 rounded-xl p-8 border border-primary/10 dark:border-emerald-900/30 reveal-up">
      <h3 class="text-xl font-bold text-slate-800 dark:text-slate-200 mb-3">Put this guide into practice</h3>
      <p class="text-slate-500 dark:text-slate-400 text-sm mb-5 leading-relaxed">FluentCards implements all the techniques discussed in this guide. Create your first deck and start applying these methods today.</p>
      <a href="/app/" class="inline-flex items-center gap-2 bg-primary text-white px-6 py-2.5 rounded-lg text-sm font-bold hover:bg-primary transition-all duration-200 shadow-sm active:scale-[0.97]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3" /></svg>
        Open FluentCards
      </a>
    </div>

    <!-- Back to Guides -->
    <div class="mt-8 text-center reveal-up">
      <a href="/guides/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 hover:text-primary transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to all guides
      </a>
    </div>
  </article>
</main>

<Footer />

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal-up').forEach(el => observer.observe(el));
</script>
</body>
</html>
