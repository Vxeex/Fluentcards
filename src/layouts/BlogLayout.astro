---
import "../styles/main.css"
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
import ThemeInit from "../components/ThemeInit.astro"
import { blogToDecks } from "../../src/fluentcards/data/contentRelations.ts";

export interface Props {
  title: string;
  description: string;
  canonical: string;
  headline: string;
  datePublished: string;
  readTime: string;
  tag: string;
}

const { title, description, canonical, headline, datePublished, readTime, tag } = Astro.props;
const fullUrl = `https://fluentcards.org${canonical}`;

// Extract slug from canonical path for content relations lookup
const slug = canonical.replace(/\/blog\//, '').replace(/\/$/, '');
const relatedDecks = blogToDecks[slug] || [];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <ThemeInit />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullUrl} />
  <!-- Open Graph / Social -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content={headline} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={fullUrl} />
  <meta property="og:site_name" content="FluentCards" />
  <meta property="og:image" content="https://fluentcards.org/images/app-screenshot.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="675" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://fluentcards.org/images/app-screenshot.jpg" />
  <meta name="twitter:title" content={headline} />
  <meta name="twitter:description" content={description} />
  <script type="application/ld+json">
  {JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": headline,
    "description": description,
    "datePublished": datePublished,
    "dateModified": datePublished,
    "author": { "@type": "Organization", "name": "FluentCards" },
    "publisher": { "@type": "Organization", "name": "FluentCards", "url": "https://fluentcards.org" },
    "mainEntityOfPage": fullUrl
  })}
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4482389932723468" crossorigin="anonymous"></script>
</head>
<body class="font-sans text-slate-700 bg-white dark:bg-surface-dark dark:text-slate-400 antialiased overflow-x-hidden transition-colors duration-300">

<Nav currentPath="/blog/" />

<!-- Article -->
<main class="pt-32 pb-16 px-6">
  <article class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-10 reveal-up">
      <span class="inline-block bg-primary-light text-primary px-3.5 py-1 rounded-full text-xs font-bold mb-4 border border-primary-light">{tag}</span>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100 leading-tight">{headline}</h1>
      <div class="mt-4 flex items-center gap-4 text-sm text-slate-400">
        <span>By FluentCards Team</span>
        <span class="w-1 h-1 rounded-full bg-slate-200"></span>
        <span>{datePublished}</span>
        <span class="w-1 h-1 rounded-full bg-slate-200"></span>
        <span>{readTime} read</span>
      </div>
    </div>

    <!-- Content -->
    <div class="article-body">
      <slot />
    </div>

    <!-- CTA -->
    <div class="mt-12 bg-white dark:bg-slate-800 rounded-xl p-8 border border-slate-200 dark:border-slate-600 reveal-up">
      <h3 class="text-xl font-bold text-slate-800 dark:text-slate-200 mb-3">Ready to start learning?</h3>
      <p class="text-slate-500 dark:text-slate-400 text-sm mb-5 leading-relaxed">Create your first deck with FluentCards and start mastering vocabulary with spaced repetition.</p>
      <a href="/app/" class="inline-flex items-center gap-2 bg-primary text-white px-6 py-2.5 rounded-lg text-sm font-bold hover:bg-primary transition-all duration-200 shadow-sm active:scale-[0.97]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3" /></svg>
        Open FluentCards
      </a>
    </div>

    <!-- Related Decks -->
    {relatedDecks.length > 0 && (
      <div class="mt-10 p-6 bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-950/30 dark:to-emerald-950/30 rounded-xl border border-primary/10 dark:border-emerald-900/30 reveal-up">
        <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-4">Practice with Flashcards</h3>
        <div class="space-y-3">
          {relatedDecks.map(deck => (
            <a
              href="/app/"
              class="block p-4 bg-white dark:bg-surface-card rounded-lg border border-primary/10 dark:border-emerald-900/30 hover:border-primary/30 hover:shadow-md transition-all group"
            >
              <div class="font-bold text-sm text-slate-800 dark:text-slate-200 group-hover:text-primary transition-colors">{deck.name}</div>
              <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">{deck.description}</div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Related Reading -->
    <div class="mt-10 p-6 bg-gradient-to-br from-slate-50 to-green-50/50 dark:from-slate-800/50 dark:to-emerald-950/20 rounded-xl border border-slate-200 dark:border-slate-600/50 reveal-up">
      <h3 class="text-base font-bold text-slate-800 dark:text-slate-200 mb-4">Related Reading</h3>
      <div class="space-y-2">
        <a href="/features/" class="block p-3 bg-white dark:bg-surface-card rounded-lg border border-slate-100 dark:border-slate-600 hover:border-primary/30 hover:shadow-md transition-all group">
          <div class="font-semibold text-sm text-slate-800 dark:text-slate-200 group-hover:text-primary transition-colors">All Features</div>
          <div class="text-xs text-slate-500 dark:text-slate-400">Explore FSRS, furigana, TTS, and AI mnemonics</div>
        </a>
        <a href="/features/anki-alternative/" class="block p-3 bg-white dark:bg-surface-card rounded-lg border border-slate-100 dark:border-slate-600 hover:border-primary/30 hover:shadow-md transition-all group">
          <div class="font-semibold text-sm text-slate-800 dark:text-slate-200 group-hover:text-primary transition-colors">FluentCards vs Anki</div>
          <div class="text-xs text-slate-500 dark:text-slate-400">See how FluentCards compares to Anki</div>
        </a>
        <a href="/guides/spaced-repetition-science/" class="block p-3 bg-white dark:bg-surface-card rounded-lg border border-slate-100 dark:border-slate-600 hover:border-primary/30 hover:shadow-md transition-all group">
          <div class="font-semibold text-sm text-slate-800 dark:text-slate-200 group-hover:text-primary transition-colors">The Science of Spaced Repetition</div>
          <div class="text-xs text-slate-500 dark:text-slate-400">Learn why spaced repetition works</div>
        </a>
      </div>
    </div>

    <!-- Back to Blog -->
    <div class="mt-8 text-center reveal-up">
      <a href="/blog/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 hover:text-primary transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to all guides
      </a>
    </div>
  </article>
</main>

<Footer />

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal-up, .reveal-pop, .reveal-scale').forEach(el => observer.observe(el));
</script>
</body>
</html>
