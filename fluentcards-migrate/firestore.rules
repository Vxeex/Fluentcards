rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidDeck(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'description', 'createdAt', 'isPublic']) &&
             (data.keys().size() == 6 || (data.keys().size() == 7 && 'authorName' in data.keys())) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.createdAt is number &&
             data.isPublic is bool &&
             (!('authorName' in data.keys()) || data.authorName == null || (data.authorName is string && data.authorName.size() <= 100));
    }

    function isValidFlashcard(data) {
      return data.keys().hasAll(['id', 'userId', 'deckId', 'front', 'back', 'language', 'useMnemonic', 'due', 'stability', 'difficulty', 'elapsed_days', 'scheduled_days', 'reps', 'lapses', 'state', 'isPublic']) &&
             (data.keys().size() == 16 || 
             (data.keys().size() == 17 && ('last_review' in data.keys() || 'targetLanguage' in data.keys())) ||
             (data.keys().size() == 18 && 'last_review' in data.keys() && 'targetLanguage' in data.keys())) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.deckId is string && data.deckId.size() <= 128 &&
             data.front is string && data.front.size() > 0 && data.front.size() <= 1000 &&
             data.back is string && data.back.size() > 0 && data.back.size() <= 1000 &&
             data.language is string && data.language.size() <= 20 &&
             (!('targetLanguage' in data.keys()) || data.targetLanguage == null || (data.targetLanguage is string && data.targetLanguage.size() <= 20)) &&
             data.useMnemonic is bool &&
             data.isPublic is bool &&
             (data.due is string || data.due is timestamp) &&
             data.stability is number &&
             data.difficulty is number &&
             data.elapsed_days is number &&
             data.scheduled_days is number &&
             data.reps is number &&
             data.lapses is number &&
             data.state is number &&
             (!('last_review' in data.keys()) || data.last_review == null || data.last_review is string || data.last_review is timestamp);
    }

    function isValidReviewLog(data) {
      return data.keys().hasAll(['id', 'userId', 'cardId', 'rating', 'reviewedAt']) &&
             data.keys().size() == 5 &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.cardId is string && data.cardId.size() <= 128 &&
             data.rating is number &&
             data.reviewedAt is number;
    }

    match /decks/{deckId} {
      allow get: if isSignedIn() && isValidId(deckId) && (resource == null || existing().userId == request.auth.uid || existing().isPublic == true);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.isPublic == true);
      allow create: if isSignedIn() && isValidId(deckId) && isValidDeck(incoming());
      allow update: if isSignedIn() && isValidId(deckId) && isValidDeck(incoming()) && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && isValidId(deckId) && existing().userId == request.auth.uid;
    }

    match /cards/{cardId} {
      allow get: if isSignedIn() && isValidId(cardId) && (resource == null || existing().userId == request.auth.uid || existing().isPublic == true);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.isPublic == true);
      allow create: if isSignedIn() && isValidId(cardId) && isValidFlashcard(incoming()) && exists(/databases/$(database)/documents/decks/$(incoming().deckId)) && get(/databases/$(database)/documents/decks/$(incoming().deckId)).data.userId == request.auth.uid && incoming().isPublic == get(/databases/$(database)/documents/decks/$(incoming().deckId)).data.get('isPublic', false);
      allow update: if isSignedIn() && isValidId(cardId) && isValidFlashcard(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isValidId(cardId) && existing().userId == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow get: if isSignedIn() && isValidId(reviewId) && (resource == null || existing().userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(reviewId) && isValidReviewLog(incoming()) && exists(/databases/$(database)/documents/cards/$(incoming().cardId)) && get(/databases/$(database)/documents/cards/$(incoming().cardId)).data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(reviewId) && existing().userId == request.auth.uid;
    }
  }
}
