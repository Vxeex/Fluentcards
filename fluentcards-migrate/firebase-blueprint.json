{
  "entities": {
    "Deck": {
      "title": "Deck",
      "description": "A collection of flashcards",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "number" },
        "isPublic": { "type": "boolean" },
        "authorName": { "type": "string", "nullable": true }
      },
      "required": ["userId", "name", "description", "createdAt", "isPublic"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A single flashcard with FSRS state",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "deckId": { "type": "string" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "language": { "type": "string" },
        "targetLanguage": { "type": "string", "nullable": true },
        "useMnemonic": { "type": "boolean" },
        "due": { "type": "string" },
        "stability": { "type": "number" },
        "difficulty": { "type": "number" },
        "elapsed_days": { "type": "number" },
        "scheduled_days": { "type": "number" },
        "reps": { "type": "number" },
        "lapses": { "type": "number" },
        "state": { "type": "number" },
        "last_review": { "type": "string", "nullable": true },
        "isPublic": { "type": "boolean" }
      },
      "required": ["userId", "deckId", "front", "back", "language", "useMnemonic", "due", "stability", "difficulty", "elapsed_days", "scheduled_days", "reps", "lapses", "state", "isPublic"]
    },
    "ReviewLog": {
      "title": "Review Log",
      "description": "A log of a card review",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "cardId": { "type": "string" },
        "rating": { "type": "number" },
        "reviewedAt": { "type": "number" }
      },
      "required": ["userId", "cardId", "rating", "reviewedAt"]
    }
  },
  "firestore": {
    "/decks/{deckId}": {
      "schema": { "$ref": "#/entities/Deck" },
      "description": "Top level collection of all decks"
    },
    "/cards/{cardId}": {
      "schema": { "$ref": "#/entities/Flashcard" },
      "description": "All flashcards"
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/ReviewLog" },
      "description": "Log of reviews"
    }
  }
}
